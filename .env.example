# --- lawless-waf configuration ---
# Copy to `.env` and adjust if needed. `.env` is gitignored and must never be committed.
# There is no API key: the app runs on your laptop (localhost-only) and the real gate is
# Azure (PIM + VPN + `az login`).

# Where downloaded/merged WAF log datasets are cached on disk.
DATA_DIR=./data

# Offline mode: when true the service never calls Azure; it only serves
# datasets already present under DATA_DIR (use `make seed`).
# Set to false to download from Azure.
OFFLINE=true

# --- Azure (only used when OFFLINE=false) ---
# No Azure secrets here: the service reuses your ambient `az login` session
# (PIM + VPN). These just parameterize the documented `az` command. You can also set
# them at runtime from the Settings tab. The container default below is the standard Azure
# Front Door WAF log name; for Application Gateway WAF use
# insights-logs-applicationgatewayfirewalllog instead.
AZURE_STORAGE_ACCOUNT=your-storage-account
AZURE_CONTAINER=insights-logs-frontdoorwebapplicationfirewalllog
AZURE_SUBSCRIPTION=your-subscription

# Comma-separated domains the app treats as "own" (a URL to one of these in a request
# param is flagged as a likely false positive instead of a remote-file-inclusion attack).
TRUSTED_DOMAINS=

# WAF logs are many tiny 5-minute blobs, so download time is dominated by per-blob overhead,
# not bandwidth — the Download-tab ETA is driven by blobs/second. This is the assumed rate;
# the Speedtest button measures the real one. Lower it if downloads feel slower than shown.
DOWNLOAD_BLOBS_PER_SEC=6

# --- abuse / cost controls ---
# Rate limit for the expensive download endpoint (requests / minute).
DOWNLOAD_RATE_LIMIT=5/minute
# Rate limit for read/analysis endpoints (requests / minute).
QUERY_RATE_LIMIT=60/minute

# CORS allowlist (comma-separated origins). The web UI (Vite) calls the API through its
# own origin via a proxy, so this can stay empty unless you call the API cross-origin.
CORS_ORIGINS=
